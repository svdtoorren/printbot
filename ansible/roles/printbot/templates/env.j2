GATEWAY_ID={{ GATEWAY_ID }}
API_KEY={{ API_KEY }}
WS_URL={{ WS_URL | default('wss://printgateway.toorren.nl/ws/gateway') }}
PRINTER_NAME={{ (PRINTER_QUEUES | selectattr('is_default', 'defined') | selectattr('is_default') | map(attribute='name') | first) if (PRINTER_QUEUES is defined and PRINTER_QUEUES | length > 0) else PRINTER_NAME }}
{% if PRINTER_QUEUES is defined and PRINTER_QUEUES | length > 0 %}
PRINTER_QUEUES={{ PRINTER_QUEUES | map(attribute='name') | join(',') }}
{% endif %}
STATE_DIR={{ STATE_DIR | default('/var/lib/printbot') }}
HEARTBEAT_INTERVAL={{ HEARTBEAT_INTERVAL | default(30) }}
RECONNECT_DELAY={{ RECONNECT_DELAY | default(5) }}
MAX_RECONNECT_DELAY={{ MAX_RECONNECT_DELAY | default(300) }}
DRY_RUN={{ DRY_RUN | default('false') }}
LOG_LEVEL={{ LOG_LEVEL | default('INFO') }}
