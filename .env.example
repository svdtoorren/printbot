# Print Gateway connection
GATEWAY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
API_KEY=pgw_your_api_key_here
WS_URL=wss://printgateway.toorren.nl/ws/gateway

# CUPS printer name (get via 'lpstat -p' on the Pi)
# Used as the default/fallback queue when a print job has no target_printer.
PRINTER_NAME=YourPrinterName

# Optional: comma-separated list of all CUPS queues managed by this gateway.
# Used for per-queue status reporting in the heartbeat and for pre-flight
# validation of the `target_printer` field on incoming jobs. Leave empty when
# only a single printer (PRINTER_NAME) is configured.
# Example for dual-tray setup: PRINTER_QUEUES=standaard,briefpapier
PRINTER_QUEUES=

# Directory for state database (SQLite job deduplication)
STATE_DIR=/var/lib/printbot

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30

# WebSocket reconnect settings (seconds)
RECONNECT_DELAY=5
MAX_RECONNECT_DELAY=300

# Dry-run mode: simulate printing without actual CUPS command
DRY_RUN=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
