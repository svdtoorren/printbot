# Print Gateway connection
GATEWAY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
API_KEY=pgw_your_api_key_here
WS_URL=wss://printgateway.toorren.nl/ws/gateway

# CUPS printer name (get via 'lpstat -p' on the Pi)
PRINTER_NAME=YourPrinterName

# Directory for state database (SQLite job deduplication)
STATE_DIR=/var/lib/printbot

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30

# WebSocket reconnect settings (seconds)
RECONNECT_DELAY=5
MAX_RECONNECT_DELAY=300

# Dry-run mode: simulate printing without actual CUPS command
DRY_RUN=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
